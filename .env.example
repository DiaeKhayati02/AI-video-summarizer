# LLM
GOOGLE_API_KEY=your_key_here
MODEL_NAME=gemini-flash-latest

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# App
BACKEND_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# Optional: only needed when deployed to a cloud host, where YouTube blocks
# transcript requests from datacenter IPs. Leave both unset locally.
#
# Option A -- a generic proxy URL, e.g. a scraping API's proxy-mode endpoint:
# TRANSCRIPT_PROXY_URL=http://scraperapi:YOUR_API_KEY@proxy-server.scraperapi.com:8001
#
# Option B -- a *residential* Webshare plan specifically (their free/datacenter
# proxies get IP-blocked the same way an unproxied host does):
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
