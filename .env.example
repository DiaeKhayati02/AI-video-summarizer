# LLM
GOOGLE_API_KEY=your_key_here
MODEL_NAME=gemini-flash-latest

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# App
BACKEND_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# Optional: only needed when deployed to a cloud host, where YouTube blocks
# transcript requests from datacenter IPs. Must be a *residential* Webshare
# plan -- their free/datacenter proxies get blocked the same way. Leave unset
# locally.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
